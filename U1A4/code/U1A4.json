        "z": "f2f4a096da5a7f3a",
        "name": "Convertir a CSV",
        "func": "let t = msg.payload.timestamp_ms;\nlet s = msg.payload.sensor_raw;\n\nmsg.payload = t + \",\" + s;\n\nreturn msg;",
