        "z": "f2f4a096da5a7f3a",
        "name": "Parse mensaje minimo",
        "func": "// Entrada ejemplo: \"12345,1\"\n\nlet partes = msg.payload.trim().split(\",\");\n\nif(partes.length >= 2){\n    msg.payload = {\n        timestamp_ms: parseInt(partes[0]),\n        sensor_raw: parseInt(partes[1])\n    };\n    return msg;\n}\n\nreturn null;",
